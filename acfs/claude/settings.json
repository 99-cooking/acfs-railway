{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "dcg"
          }
        ]
      }
    ]
  },
  "mcpServers": {
    "mcp-agent-mail": {
      "type": "stdio",
      "command": "/opt/acfs/mcp-agent-mail/.venv/bin/python",
      "args": ["-m", "mcp_agent_mail.cli", "serve-stdio"],
      "env": {
        "STORAGE_ROOT": "/data/mcp-agent-mail/mailbox",
        "LLM_ENABLED": "false",
        "TOOLS_LOG_ENABLED": "false",
        "LOG_RICH_ENABLED": "false"
      }
    }
  }
}
